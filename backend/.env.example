# Kama backend — copy to .env for local dev. Production: set on Railway.

APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Postgres — local docker-compose uses port 5433
DATABASE_URL=postgresql+asyncpg://kama:kama_local@127.0.0.1:5433/kama
# Railway provides postgresql://... — auto-normalized to asyncpg at runtime

REDIS_URL=redis://127.0.0.1:6379/0

# Clerk JWT validation (required when DISABLE_AUTH=false)
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
DISABLE_AUTH=true

# Object storage — AWS S3 or S3-compatible (R2, MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT_URL=

# Qdrant — local docker-compose, or Qdrant Cloud in production
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Admin (comma-separated Clerk user IDs for /api/admin/*)
ADMIN_USER_IDS=

# LLM — set one provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional integrations
YOUTUBE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
# Or inline JSON for Railway (preferred over file mount):
GOOGLE_CREDENTIALS_JSON=

# Observability
SENTRY_DSN=
